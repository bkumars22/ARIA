# ─── PRODUCTION — fill in your Render.com URLs ────────────────
# Step 1: Deploy ai-service to Render.com (see instructions below)
# Step 2: Replace the AI service URL below with your actual Render URL
# Step 3: Run:  npm run build  then  npx gh-pages -d dist --no-history

# Set to false when backend is running on Render.com
REACT_APP_DEMO_MODE=true

# Spring Boot backend (needed for auth, history, sessions)
REACT_APP_API_URL=https://aria-backend.onrender.com/aria

# FastAPI AI service — THE KEY to genuine answers
# When this is set, ALL uploaded documents and questions go to REAL Claude AI
# Deploy ai-service/ to Render.com and paste the URL here:
REACT_APP_AI_SERVICE_URL=https://aria-ai.onrender.com
