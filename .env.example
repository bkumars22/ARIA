# Copy this to .env and fill in real values
ANTHROPIC_API_KEY=sk-ant-your-key-here
JWT_SECRET=aria-jwt-secret-min-32-chars-long-2026

# Database (docker-compose sets these automatically)
POSTGRES_DB=aria_db
POSTGRES_USER=aria
POSTGRES_PASSWORD=aria_secret

# Service URLs (docker-compose sets these automatically)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/aria_db
AI_SERVICE_URL=http://localhost:8001
BACKEND_URL=http://localhost:8089/aria
